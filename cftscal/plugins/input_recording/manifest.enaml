from cftscal.util import list_inputs
from cftscal.plugins.manifest import CalibrationPluginManifest

from .settings import InputRecordingSettings
from .view import InputRecordingView


enamldef InputRecordingManifest(CalibrationPluginManifest):

    id = 'input-recording'
    title = 'Input Recording'
    shortcut = 'Ctrl+i'

    view_class = InputRecordingView
    settings_class = InputRecordingSettings
    settings_config = {
        'inputs': list_inputs,
    }
