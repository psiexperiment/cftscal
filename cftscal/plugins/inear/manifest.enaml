from cftscal.util import list_starship_connections
from ..manifest import CalibrationPluginManifest
from .settings import InEarCalibrationSettings
from .view import InEarView


enamldef InEarManifest(CalibrationPluginManifest): manifest:

    id = 'inear'
    title = 'Starship Check'
    shortcut = 'Ctrl+i'

    view_class = InEarView
    settings_class = InEarCalibrationSettings
    settings_config = {
        'outputs': list_starship_connections,
    }
